{
  "name": "pos-akhairi-com",
  "version": "0.1.0",
  "private": true,
  "description": "Bakmie resto POS — monorepo (Sprint 0 scaffold)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run db:generate -w @pos/db",
    "db:migrate": "npm run db:migrate -w @pos/db",
    "db:seed": "npm run db:seed -w @pos/db"
  },
  "engines": {
    "node": ">=22"
  }
}
