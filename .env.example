# POS Akhairi Production Environment Example
# Copy to .env and fill in production secrets

NODE_ENV=production
API_HOST=0.0.0.0
API_PORT=8787
DATABASE_URL=postgresql://user:password@localhost:5432/pos_akhairi
REDIS_URL=redis://localhost:6379

# CRITICAL: Must be unique, random, and at least 32 bytes
JWT_SECRET=YOUR_RANDOM_JWT_SECRET_HERE

# CRITICAL: Must be 32 bytes (base64 or hex)
CHANNEL_ENCRYPTION_KEY=YOUR_RANDOM_CHANNEL_ENCRYPTION_KEY_HERE

# CRITICAL: Production web origin (e.g. https://pos.akhairi.com)
WEB_ORIGIN=https://pos.akhairi.com

# Payment Providers
XENDIT_SECRET_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_ENV=production
