// Prisma 7.8 schema (Sprint 0)
// Note: Prisma 7.x introduces a new schema syntax. We use the stable 5.x-style
// syntax that Prisma 7 still accepts, with explicit @@map/@@id where useful.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  CASHIER
  KITCHEN
}

enum OrderStatus {
  OPEN
  SENT_TO_KDS
  IN_PROGRESS
  READY
  SERVED
  PAID
  CANCELLED
  VOIDED
  REFUNDED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum PaymentMethod {
  CASH
  QRIS
  DEBIT
  CREDIT
  EWALLET
  PENDING
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum InventoryMovementType {
  PURCHASE
  USAGE
  WASTE
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         UserRole @default(CASHIER)
  branchId     String?  @map("branch_id")
  branch       Branch?  @relation(fields: [branchId], references: [id])
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  shifts         Shift[]
  ordersOpened   Order[] @relation("OrderOpenedBy")
  ordersClosed   Order[] @relation("OrderClosedBy")
  ordersVoided   Order[] @relation("OrderVoidedBy")
  ordersRefunded Order[] @relation("OrderRefundedBy")

  // Sprint 5.5
  branchAccess        UserBranchAccess[]
  transfersCreated    StockTransfer[]    @relation("TransferCreated")
  transfersSent       StockTransfer[]    @relation("TransferSent")
  transfersReceived   StockTransfer[]    @relation("TransferReceived")

  @@index([branchId])
  @@index([role])
  @@map("users")
}

model Branch {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  address   String?
  city      String?
  phone     String?
  timezone  String   @default("Asia/Jakarta")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users             User[]
  orders            Order[]
  shifts            Shift[]
  menuItems         MenuItem[]
  inventory         InventoryItem[]
  discounts         Discount[]
  channelConfigs    ChannelConfig[]
  channelOrders     ChannelOrder[]
  dailyCloses       DailyClose[]
  commissionReports CommissionReport[]

  // Sprint 5
  userAccess        UserBranchAccess[]
  transfersFrom     StockTransfer[]    @relation("TransferFrom")
  transfersTo       StockTransfer[]    @relation("TransferTo")

  @@map("branches")
}

model CommissionReport {
  id                        String    @id @default(cuid())
  branchId                  String
  branch                    Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  channel                   Channel
  businessDate              DateTime  @db.Date
  localCommissionCents      Int       @default(0)
  localOrderCount           Int       @default(0)
  localBilledCents          Int?
  aggregatorCommissionCents Int?
  aggregatorOrderCount      Int?
  aggregatorBilledCents     Int?
  deltaCents                Int?
  status                    String // MATCH | MISMATCH | FETCH_FAILED | NO_DATA
  notes                     String?
  resolvedBy                String?
  resolvedAt                DateTime?
  createdBy                 String
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@unique([branchId, channel, businessDate], name: "branchId_channel_businessDate")
  @@index([branchId, businessDate])
  @@index([status])
  @@map("commission_reports")
}

model MenuCategory {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id          String       @id @default(cuid())
  branchId    String       @map("branch_id")
  branch      Branch       @relation(fields: [branchId], references: [id])
  categoryId  String       @map("category_id")
  category    MenuCategory @relation(fields: [categoryId], references: [id])
  sku         String
  name        String
  description String?
  priceCents  Int          @map("price_cents")
  costCents   Int          @default(0) @map("cost_cents")
  taxRateBp   Int          @default(1100) @map("tax_rate_bp") // basis points: 1100 = 11%
  isActive    Boolean      @default(true) @map("is_active")
  isAvailable Boolean      @default(true) @map("is_available")
  imageUrl    String?      @map("image_url")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  modifiers  Modifier[]
  recipes    Recipe[]
  orderItems OrderItem[]

  @@unique([branchId, sku])
  @@index([categoryId])
  @@index([branchId, isActive])
  @@map("menu_items")
}

model Modifier {
  id              String   @id @default(cuid())
  menuItemId      String   @map("menu_item_id")
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name            String
  priceDeltaCents Int      @default(0) @map("price_delta_cents")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([menuItemId])
  @@map("modifiers")
}

model Recipe {
  id              String        @id @default(cuid())
  menuItemId      String        @map("menu_item_id")
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  inventoryItemId String        @map("inventory_item_id")
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Decimal       @db.Decimal(12, 4)
  unit            String
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@unique([menuItemId, inventoryItemId])
  @@index([inventoryItemId])
  @@map("recipes")
}

model Order {
  id            String      @id @default(cuid())
  branchId      String      @map("branch_id")
  branch        Branch      @relation(fields: [branchId], references: [id])
  shiftId       String?     @map("shift_id")
  shift         Shift?      @relation(fields: [shiftId], references: [id])
  orderNumber   String      @map("order_number")
  type          OrderType   @default(DINE_IN)
  status        OrderStatus @default(OPEN)
  tableNumber   String?     @map("table_number")
  customerName  String?     @map("customer_name")
  notes         String?
  subtotalCents Int         @default(0) @map("subtotal_cents")
  taxCents      Int         @default(0) @map("tax_cents")
  discountCents Int         @default(0) @map("discount_cents")
  totalCents    Int         @default(0) @map("total_cents")
  openedById    String      @map("opened_by_id")
  openedBy      User        @relation("OrderOpenedBy", fields: [openedById], references: [id])
  closedById    String?     @map("closed_by_id")
  closedBy      User?       @relation("OrderClosedBy", fields: [closedById], references: [id])
  openedAt      DateTime    @default(now()) @map("opened_at")
  closedAt      DateTime?   @map("closed_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // Discount (S2.5)
  discountId String?   @map("discount_id")
  discount   Discount? @relation(fields: [discountId], references: [id])

  // Void (S2.4)
  voidedAt   DateTime? @map("voided_at")
  voidedById String?   @map("voided_by_id")
  voidedBy   User?     @relation("OrderVoidedBy", fields: [voidedById], references: [id])
  voidReason String?   @map("void_reason")

  // Refund (S2.4)
  refundedAt      DateTime? @map("refunded_at")
  refundedById    String?   @map("refunded_by_id")
  refundedBy      User?     @relation("OrderRefundedBy", fields: [refundedById], references: [id])
  refundReason    String?   @map("refund_reason")
  refundMethod    String?   @map("refund_method") // CASH | ORIGINAL
  refundPaymentId String?   @map("refund_payment_id")

  items         OrderItem[]
  payments      Payment[]
  channelOrders ChannelOrder[]

  @@unique([branchId, orderNumber])
  @@index([status])
  @@index([branchId, openedAt])
  @@map("orders")
}

model OrderItem {
  id             String      @id @default(cuid())
  orderId        String      @map("order_id")
  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId     String      @map("menu_item_id")
  menuItem       MenuItem    @relation(fields: [menuItemId], references: [id])
  nameSnapshot   String      @map("name_snapshot")
  priceCents     Int         @map("price_cents")
  quantity       Int         @default(1)
  notes          String?
  status         OrderStatus @default(OPEN)
  modifiersJson  Json?       @map("modifiers_json")
  lineTotalCents Int         @map("line_total_cents")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String        @map("order_id")
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider    String        @default("CASH")
  method      PaymentMethod @default(PENDING)
  status      PaymentStatus @default(PENDING)
  amountCents Int           @map("amount_cents")
  reference   String?
  providerRaw Json?         @map("provider_raw")
  paidAt      DateTime?     @map("paid_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([status])
  @@map("payments")
}

model Shift {
  id            String      @id @default(cuid())
  branchId      String      @map("branch_id")
  branch        Branch      @relation(fields: [branchId], references: [id])
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id])
  status        ShiftStatus @default(OPEN)
  openingCents  Int         @default(0) @map("opening_cents")
  closingCents  Int?        @map("closing_cents")
  expectedCents Int?        @map("expected_cents")
  varianceCents Int?        @map("variance_cents")
  openedAt      DateTime    @default(now()) @map("opened_at")
  closedAt      DateTime?   @map("closed_at")
  notes         String?

  orders      Order[]
  dailyCloses DailyClose[]

  @@index([branchId, status])
  @@index([userId])
  @@map("shifts")
}

model DailyClose {
  id       String  @id @default(cuid())
  branchId String  @map("branch_id")
  branch   Branch  @relation(fields: [branchId], references: [id])
  shiftId  String? @map("shift_id")
  shift    Shift?  @relation(fields: [shiftId], references: [id])

  // Calendar
  businessDate DateTime @map("business_date") @db.Date
  timezone     String   @default("Asia/Jakarta") @map("timezone")

  // Status
  status   String    @default("OPEN") // OPEN | CLOSED | RECONCILED
  closedAt DateTime? @map("closed_at")
  closedBy String?   @map("closed_by") // "AUTO" or user id

  // Order counts
  ordersTotal    Int @default(0) @map("orders_total")
  ordersVoided   Int @default(0) @map("orders_voided")
  ordersRefunded Int @default(0) @map("orders_refunded")

  // Local totals (from Orders + ChannelOrders)
  grossCents        Int @default(0) @map("gross_cents")
  discountCents     Int @default(0) @map("discount_cents")
  taxCents          Int @default(0) @map("tax_cents")
  netCents          Int @default(0) @map("net_cents")
  deliveryFeeCents  Int @default(0) @map("delivery_fee_cents")
  serviceFeeCents   Int @default(0) @map("service_fee_cents")
  commissionCents   Int @default(0) @map("commission_cents") // local-computed
  netAfterCommCents Int @default(0) @map("net_after_comm_cents")

  // By payment method (JSON: {CASH: 100000, QRIS: 200000, ...})
  byPaymentJson Json @default("{}") @map("by_payment_json")
  // By channel (JSON: {DINE_IN: ..., GOFOOD: ..., GRABFOOD: ..., ...})
  byChannelJson Json @default("{}") @map("by_channel_json")

  // Aggregator-reported (Sprint 4.2: reconciliation)
  aggregatorReportJson    Json?     @map("aggregator_report_json")
  commissionReportedCents Int?      @map("commission_reported_cents")
  commissionVarianceCents Int?      @map("commission_variance_cents")
  reconciledAt            DateTime? @map("reconciled_at")
  reconciliationNotes     String?   @map("reconciliation_notes")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([branchId, businessDate])
  @@index([businessDate])
  @@index([status])
  @@map("daily_closes")
}

model InventoryItem {
  id           String   @id @default(cuid())
  branchId     String   @map("branch_id")
  branch       Branch   @relation(fields: [branchId], references: [id])
  sku          String
  name         String
  unit         String
  quantity     Decimal  @default(0) @db.Decimal(12, 4)
  reorderPoint Decimal  @default(0) @map("reorder_point") @db.Decimal(12, 4)
  costPerUnit  Decimal  @default(0) @map("cost_per_unit") @db.Decimal(12, 4)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  logs        InventoryLog[]
  recipes     Recipe[]
  transfers   StockTransferItem[]

  @@unique([branchId, sku])
  @@index([branchId, isActive])
  @@map("inventory_items")
}

model InventoryLog {
  id              String                @id @default(cuid())
  inventoryItemId String                @map("inventory_item_id")
  inventoryItem   InventoryItem         @relation(fields: [inventoryItemId], references: [id])
  type            InventoryMovementType
  quantity        Decimal               @db.Decimal(12, 4)
  unitCostCents   Int?                  @map("unit_cost_cents")
  reason          String?
  reference       String?
  createdAt       DateTime              @default(now()) @map("created_at")

  @@index([inventoryItemId, createdAt])
  @@map("inventory_logs")
}

model Discount {
  id               String       @id @default(cuid())
  branchId         String       @map("branch_id")
  branch           Branch       @relation(fields: [branchId], references: [id])
  code             String?      @unique
  name             String
  type             DiscountType
  // For PERCENTAGE: value is 0-100 (integer percent).
  // For FIXED: value is cents.
  value            Int
  minOrderCents    Int          @default(0) @map("min_order_cents")
  maxDiscountCents Int?         @map("max_discount_cents")
  validFrom        DateTime?    @map("valid_from")
  validUntil       DateTime?    @map("valid_until")
  usageLimit       Int?         @map("usage_limit")
  usageCount       Int          @default(0) @map("usage_count")
  isActive         Boolean      @default(true) @map("is_active")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  orders Order[]

  @@index([branchId, isActive])
  @@index([code])
  @@map("discounts")
}

// ─── Sprint 3: Delivery aggregators ──────────────────────────────────────────

enum Channel {
  POS // order created directly in POS
  GOFOOD
  GRABFOOD
  SHOPEEFOOD
  MANUAL // phone / WhatsApp / in-person
}

// Sprint 5.5 — multi-branch user access
model UserBranchAccess {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  branchId  String   @map("branch_id")
  role      UserRole @default(CASHIER) // role scoped to this branch (OWNER might be MANAGER at another)
  isDefault Boolean  @default(false) @map("is_default")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, branchId])
  @@index([branchId])
  @@map("user_branch_access")
}

// Sprint 5.2 — stock transfer between branches
enum StockTransferStatus {
  DRAFT
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

model StockTransfer {
  id            String             @id @default(cuid())
  fromBranchId  String             @map("from_branch_id")
  toBranchId    String             @map("to_branch_id")
  status        StockTransferStatus @default(DRAFT)
  notes         String?
  createdById   String             @map("created_by_id")
  sentById      String?            @map("sent_by_id")
  receivedById  String?            @map("received_by_id")
  createdAt     DateTime           @default(now()) @map("created_at")
  sentAt        DateTime?          @map("sent_at")
  receivedAt    DateTime?          @map("received_at")
  cancelledAt   DateTime?          @map("cancelled_at")

  fromBranch Branch                @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranch   Branch                @relation("TransferTo", fields: [toBranchId], references: [id])
  createdBy  User                  @relation("TransferCreated", fields: [createdById], references: [id])
  sentBy     User?                 @relation("TransferSent", fields: [sentById], references: [id])
  receivedBy User?                 @relation("TransferReceived", fields: [receivedById], references: [id])
  items      StockTransferItem[]

  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([status])
  @@map("stock_transfers")
}

model StockTransferItem {
  id                String        @id @default(cuid())
  transferId        String        @map("transfer_id")
  inventoryItemId   String        @map("inventory_item_id")
  qtyTransferred    Int           @map("qty_transferred")
  qtyReceived       Int?          @map("qty_received")
  transfer          StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([transferId])
  @@map("stock_transfer_items")
}

enum ChannelOrderStatus {
  PENDING // received from channel, not yet accepted
  ACCEPTED // accepted by kitchen
  REJECTED // rejected (out of stock, closed, etc.)
  PREPARING // being cooked
  READY // ready for pickup by driver
  PICKED_UP // driver picked up
  DELIVERED
  CANCELLED
  REFUNDED
}

model ChannelConfig {
  id                 String    @id @default(cuid())
  branchId           String    @map("branch_id")
  branch             Branch    @relation(fields: [branchId], references: [id])
  channel            Channel
  enabled            Boolean   @default(false)
  storeId            String?   @map("store_id")
  apiKeyEncrypted    String?   @map("api_key_encrypted")
  apiSecretEncrypted String?   @map("api_secret_encrypted")
  webhookSecret      String?   @map("webhook_secret")
  // Polling settings (for fallback)
  pollIntervalSec    Int       @default(60) @map("poll_interval_sec")
  lastPolledAt       DateTime? @map("last_polled_at")
  // Aggregator-specific JSON config (store hours, delivery radius, etc.)
  configJson         Json?     @map("config_json")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  orders ChannelOrder[]

  @@unique([branchId, channel])
  @@index([channel, enabled])
  @@map("channel_configs")
}

model ChannelOrder {
  id               String             @id @default(cuid())
  branchId         String             @map("branch_id")
  branch           Branch             @relation(fields: [branchId], references: [id])
  channel          Channel
  channelConfigId  String?            @map("channel_config_id")
  channelConfig    ChannelConfig?     @relation(fields: [channelConfigId], references: [id])
  externalId       String             @map("external_id") // aggregator order id
  externalRef      String?            @map("external_ref") // human ref
  status           ChannelOrderStatus @default(PENDING)
  // Customer & delivery
  customerName     String?            @map("customer_name")
  customerPhone    String?            @map("customer_phone")
  deliveryAddress  String?            @map("delivery_address")
  deliveryLat      Decimal?           @map("delivery_lat") @db.Decimal(9, 6)
  deliveryLng      Decimal?           @map("delivery_lng") @db.Decimal(9, 6)
  deliveryNotes    String?            @map("delivery_notes")
  driverName       String?            @map("driver_name")
  driverPhone      String?            @map("driver_phone")
  // Money
  subtotalCents    Int                @default(0) @map("subtotal_cents")
  deliveryFeeCents Int                @default(0) @map("delivery_fee_cents")
  serviceFeeCents  Int                @default(0) @map("service_fee_cents")
  discountCents    Int                @default(0) @map("discount_cents")
  commissionCents  Int                @default(0) @map("commission_cents")
  totalCents       Int                @default(0) @map("total_cents")
  // Linkage to local order (created when accepted)
  orderId          String?            @map("order_id")
  order            Order?             @relation(fields: [orderId], references: [id])
  // Payload
  itemsJson        Json               @map("items_json")
  rawPayload       Json?              @map("raw_payload")
  // Lifecycle
  receivedAt       DateTime           @default(now()) @map("received_at")
  acceptedAt       DateTime?          @map("accepted_at")
  preparedAt       DateTime?          @map("prepared_at")
  deliveredAt      DateTime?          @map("delivered_at")
  cancelledAt      DateTime?          @map("cancelled_at")
  cancelReason     String?            @map("cancel_reason")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  events ChannelOrderEvent[]

  @@unique([channel, externalId])
  @@index([branchId, status])
  @@index([channel, status])
  @@index([orderId])
  @@map("channel_orders")
}

model ChannelOrderEvent {
  id             String             @id @default(cuid())
  channelOrderId String             @map("channel_order_id")
  channelOrder   ChannelOrder       @relation(fields: [channelOrderId], references: [id], onDelete: Cascade)
  status         ChannelOrderStatus
  // For tracking who/what triggered: SYSTEM | KITCHEN | DRIVER | AGGREGATOR
  actor          String             @default("SYSTEM")
  note           String?
  raw            Json?
  createdAt      DateTime           @default(now()) @map("created_at")

  @@index([channelOrderId, createdAt])
  @@map("channel_order_events")
}
