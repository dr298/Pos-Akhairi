# syntax=docker/dockerfile:1.7

# ---------- deps ----------
FROM node:22-alpine AS deps
WORKDIR /repo
COPY package.json package-lock.json* ./
COPY apps/api/package.json apps/api/package.json
COPY apps/web/package.json apps/web/package.json
COPY packages/db/package.json packages/db/package.json
RUN npm install

# ---------- web build ----------
FROM node:22-alpine AS web-build
WORKDIR /repo/apps/web
ENV NEXT_TELEMETRY_DISABLED=1
# Hoisted node_modules from /repo contains @next, react, etc.
COPY --from=deps /repo/node_modules /repo/node_modules
COPY --from=deps /repo/package.json /repo/package.json
COPY apps/web/package.json ./
COPY apps/web/next.config.mjs ./
COPY apps/web/tsconfig.json ./
COPY apps/web/next-env.d.ts ./
COPY apps/web/src ./src
COPY apps/web/public ./public
# Prisma client not needed for web build (api uses it)
RUN cd /repo/apps/web && npx next build

# ---------- web runtime ----------
FROM node:22-alpine AS web
WORKDIR /app
RUN apk add --no-cache wget && \
    addgroup -S app && adduser -S app -G app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
COPY --from=web-build --chown=app:app /repo/apps/web/.next/standalone ./
COPY --from=web-build --chown=app:app /repo/apps/web/.next/static ./apps/web/.next/static
COPY --from=web-build --chown=app:app /repo/apps/web/public ./apps/web/public
USER app
EXPOSE 3000
HEALTHCHECK --interval=10s --timeout=5s --retries=6 --start-period=20s \
  CMD wget -qO- http://localhost:3000 || exit 1
CMD ["sh", "-c", "cd apps/web && exec node server.js"]
