# syntax=docker/dockerfile:1.7

# ---------- deps ----------
FROM node:22-bullseye AS deps
WORKDIR /repo
COPY package.json package-lock.json* ./
COPY apps/api/package.json apps/api/package.json
COPY apps/web/package.json apps/web/package.json
COPY packages/db/package.json packages/db/package.json
RUN npm install

# ---------- web build ----------
FROM node:22-bullseye AS web-build
WORKDIR /repo/apps/web
ENV NEXT_TELEMETRY_DISABLED=1
# Force production for build to avoid Next 16 prerender warnings on /_global-error
ENV NODE_ENV=production
# Build-time envs (NEXT_PUBLIC_* must be present at build, not runtime)
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ARG NEXT_PUBLIC_PRINTER_ENABLED
ENV NEXT_PUBLIC_PRINTER_ENABLED=${NEXT_PUBLIC_PRINTER_ENABLED}
# Hoisted node_modules from /repo contains @next, react, etc.
COPY --from=deps /repo/node_modules /repo/node_modules
COPY --from=deps /repo/package.json /repo/package.json
COPY apps/web/package.json ./
COPY apps/web/next.config.mjs ./
COPY apps/web/postcss.config.mjs ./
COPY apps/web/tsconfig.json ./
COPY apps/web/next-env.d.ts ./
COPY apps/web/src ./src
COPY apps/web/public ./public
# Prisma client not needed for web build (api uses it)
RUN cd /repo/apps/web && npx next build

# ---------- web runtime ----------
FROM node:22-bullseye-slim AS web
WORKDIR /app
RUN apt-get update && apt-get install -y wget && rm -rf /var/lib/apt/lists/* && \
    groupadd -r app && useradd -r -g app app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
COPY --from=web-build --chown=app:app /repo/apps/web/.next/standalone ./
COPY --from=web-build --chown=app:app /repo/apps/web/.next/static ./apps/web/.next/static
COPY --from=web-build --chown=app:app /repo/apps/web/public ./apps/web/public
USER app
EXPOSE 3000
HEALTHCHECK --interval=10s --timeout=5s --retries=6 --start-period=20s \
  CMD wget -qO- http://0.0.0.0:3000 || exit 1
CMD ["sh", "-c", "cd apps/web && exec node server.js"]
